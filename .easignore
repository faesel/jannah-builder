# EAS ignore — when present, EAS uses this INSTEAD of .gitignore for build uploads.
# Keep in sync with .gitignore, plus exclude store/publishing assets from the app build.

# Store listing assets (feature graphic, screenshots, icons) — not part of the app
store/

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# user-exported profile/state snapshots (personal data)
jannah-state-*.json

# EAS credentials export (contains keystore + passwords)
credentials.json
credentials/
