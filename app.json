{
  "expo": {
    "name": "Jannah Builder",
    "slug": "jannah-builder",
    "version": "2.14.10",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "jannahbuilder",
    "backgroundColor": "#F5F7F3",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jannahbuilder.app",
      "infoPlist": {
        "NSCameraUsageDescription": "This app does not use the camera.",
        "NSPhotoLibraryUsageDescription": "This app does not access photos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4A7C59"
      },
      "package": "com.jannahbuilder.app",
      "versionCode": 21
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "a47fe107-49c8-4455-8204-0249b0ffe509"
      },
      "router": {}
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F5F7F3",
          "image": "./assets/splash-icon.png",
          "imageWidth": 280
        }
      ],
      "./plugins/withAndroidRelease"
    ]
  }
}
